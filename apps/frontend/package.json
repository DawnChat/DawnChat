{
  "name": "@dawnchat/frontend",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "typecheck": "vue-tsc -b",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:run": "vitest run",
    "e2e": "playwright test --config=e2e/playwright.config.ts",
    "e2e:ui": "playwright test --config=e2e/playwright.config.ts --ui",
    "e2e:headed": "playwright test --config=e2e/playwright.config.ts --headed",
    "e2e:report": "playwright show-report e2e/playwright-report",
    "e2e:mock": "playwright test --config=e2e/playwright.mock.config.ts",
    "e2e:mock:ui": "playwright test --config=e2e/playwright.mock.config.ts --ui",
    "e2e:mock:headed": "playwright test --config=e2e/playwright.mock.config.ts --headed",
    "e2e:mock:report": "playwright show-report e2e/playwright-report-mock",
    "api:generate": "cd ../.. && ./scripts/generate-api-types.sh",
    "api:generate:from-schema": "cd ../.. && ./scripts/generate-api-types.sh --from-schema",
    "api:verify": "cd ../.. && ./scripts/generate-api-types.sh --verify",
    "api:verify-local": "cd ../.. && ./scripts/generate-api-types.sh --verify-local",
    "lint:boundaries": "node ./scripts/check-boundaries.mjs"
  },
  "dependencies": {
    "@dawnchat/auth-bridge": "workspace:*",
    "@dawnchat/shared-protocol": "workspace:*",
    "@dawnchat/shared-ui": "workspace:*",
    "@opencode-ai/sdk": "^1.2.27",
    "@supabase/supabase-js": "^2.81.1",
    "@tauri-apps/api": "^2.8.5",
    "@tauri-apps/plugin-deep-link": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.4.2",
    "@tauri-apps/plugin-fs": "^2.0.0",
    "@tauri-apps/plugin-opener": "^2.5.2",
    "@tauri-apps/plugin-shell": "^2.3.3",
    "@tauri-apps/plugin-store": "^2.4.1",
    "@types/dagre": "^0.7.53",
    "@vue/compiler-dom": "^3.5.24",
    "@vue/server-renderer": "^3.5.24",
    "dagre": "^0.8.5",
    "dexie": "^4.0.11",
    "highlight.js": "^11.11.1",
    "lucide-vue-next": "^0.562.0",
    "markdown-it": "^14.1.0",
    "dompurify": "^3.2.6",
    "pinia": "^3.0.4",
    "vue": "^3.5.22",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^24.6.0",
    "@types/markdown-it": "^14.1.2",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vitest/ui": "^4.0.9",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "happy-dom": "^20.0.10",
    "openapi-typescript": "^7.10.1",
    "typescript": "~5.9.3",
    "vite": "^7.1.7",
    "vitest": "^4.0.9",
    "vue-tsc": "^3.1.0"
  }
}
