{
  "typeCheckingMode": "basic",
  "include": [
    "packages/backend-kernel/app",
    "dawnchat-plugins/official-plugins",
    "dawnchat-plugins/sdk"
  ],
  "reportArgumentType": "none",
  "reportCallIssue": "none",
  "reportMissingTypeArgument": "none",
  "reportOptionalIterable": "none",
  "reportAssignmentType": "none",
  "reportAttributeAccessIssue": "none",
  "reportOptionalMemberAccess": "none",
  "reportIndexIssue": "none",
  "reportUndefinedVariable": "none",
  "reportGeneralTypeIssues": "none",
  "executionEnvironments": [
    {
      "root": "packages/backend-kernel",
      "pythonVersion": "3.11",
      "enableExperimentalFeatures": true,
      "reportMissingImports": "none",
      "reportMissingTypeStubs": "none",
      "reportMissingModuleSource": "none",
      "reportArgumentType": "none",
      "reportMissingTypeArgument": "none",
      "reportCallIssue": "none",
      "reportAttributeAccessIssue": "none",
      "reportOptionalMemberAccess": "none",
      "reportIndexIssue": "none",
      "reportUndefinedVariable": "none",
      "reportGeneralTypeIssues": "none"
    },
    {
      "root": "dawnchat-plugins/official-plugins",
      "pythonVersion": "3.11",
      "enableExperimentalFeatures": true,
      "extraPaths": [
        "dawnchat-plugins/sdk"
      ],
      "reportMissingImports": "none",
      "reportMissingTypeStubs": "none",
      "reportMissingModuleSource": "none",
      "reportArgumentType": "none",
      "reportMissingTypeArgument": "none",
      "reportCallIssue": "none",
      "reportAttributeAccessIssue": "none",
      "reportOptionalMemberAccess": "none",
      "reportIndexIssue": "none",
      "reportUndefinedVariable": "none",
      "reportGeneralTypeIssues": "none"
    }
  ],
  "exclude": [
    "**/node_modules",
    "**/__pycache__",
    "**/.venv",
    "**/.pytest_cache",
    "**/.mypy_cache",
    "**/target",
    "**/dist",
    "**/build",
    "apps/desktop/src-tauri/sidecars",
    "apps/desktop/src-tauri/target",
    "cloud/supabase/.temp",
    "debug-log",
    "docker-local",
    "docs",
    "download",
    "log",
    "packages/backend-kernel/app/agent",
    "packages/backend-kernel/app/pipeline",
    "packages/backend-kernel/app/pipeline_v2",
    "DawnChatWeb",
    "tests",
    "test_*",
    "sidecars",
    "dawnchat-plugins/official-plugins/comfyui/src/comfyui",
    "dawnchat-plugins/official-plugins/comfyui/src/comfyui_wrapper",
    "dawnchat-plugins/official-plugins/vibevoice/src/vibevoice",
    "dawnchat-plugins/official-plugins/vibevoice/src/vibevoice_worker",
    "dawnchat-plugins/official-plugins/cosyvoice/src/cosyvoice",
    "dawnchat-plugins/official-plugins/cosyvoice/src/cosyvoice_worker",
    "dawnchat-plugins/official-plugins/cosyvoice/src/third_party",
    "dawnchat-plugins/official-plugins/comfyui/src/local_overrides",
    "dawnchat-plugins/official-plugins/comfyui/src/local_overrides/custom_nodes",
    "dawnchat-plugins/official-plugins/vibevoice/src/local_overrides",
    "dawnchat-plugins/official-plugins/cosyvoice/src/local_overrides"
  ]
}
